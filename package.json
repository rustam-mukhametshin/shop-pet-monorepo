{
  "name": "nodejs-complete-guide",
  "version": "1.0.0",
  "description": "Complete Node.js Guide",
  "main": "app.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "nodemon app.js",
    "start-dev": "nodemon --inspect app.js",
    "start-server": "nodemon app.js",
    "start:ts": "ts-node app.ts",
    "start:ts-dev": "nodemon --exec ts-node app.ts",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc -p tsconfig.build.json"
  },
  "author": "Rustam",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.11",
    "@types/node": "^24.5.2",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "mongodb": "^7.1.1",
    "mysql2": "^3.20.0",
    "sequelize": "^6.37.8"
  }
}
