<%- include('./../parts/head') %>
<%- include('./../parts/head-end') %>
<%- include('./../parts/body') %>
<%- include('./../parts/navigation') %>

<main>
    <% if(prods.length > 0) { %>
        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                <div>
                    <h1 class="h3 mb-1">Products</h1>
                    <p class="text-muted mb-0">Browse all available products.</p>
                </div>
                <span class="badge text-bg-success"><%= prods.length %> item(s)</span>
            </div>

            <div class="row g-4">
                <% for(let product of prods) { %>
                    <div class="col-12 col-md-6 col-xl-4">
                        <article class="card h-100 shadow-sm border-0 overflow-hidden">
                            <img src="<%- product.imageUrl %>" class="card-img-top" alt="<%= product.title %>">
                            <div class="card-body d-flex flex-column">
                                <h2 class="card-title h5"><%= product.title %></h2>
                                <p class="text-success fw-semibold mb-2">$ <%= product.price %></p>
                                <p class="card-text text-muted flex-grow-1"><%= product.description %></p>
                                <div class="d-grid mt-3">
                                    <%- include('./../parts/add-to-cart', {product: product}) %>
                                </div>
                            </div>
                        </article>
                    </div>
                <% } %>
            </div>
        </div>

        <%- include('./../parts/pagination') %>
    <% } else { %>
        <div class="container py-4">
            <div class="alert alert-info mb-0">No products found.</div>
        </div>
    <% } %>
</main>
<%- include('./../parts/body-end') %>