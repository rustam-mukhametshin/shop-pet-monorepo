<%- include('./../parts/head') %>
<%- include('./../parts/head-end') %>
<%- include('./../parts/body') %>
<%- include('./../parts/navigation') %>

<main>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-3">Reset</h1>
                        <p class="text-muted mb-4">Renew your password for <b><%= _email %></b> to get started.</p>

                        <%- include('./../parts/error-msg') %>

                        <form action="/reset-password" method="post">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <input type="hidden" name="_email" value="<%= _email %>">
                            <input type="hidden" name="_token" value="<%= _token %>">

                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input id="password" name="password" type="password" class="form-control">
                            </div>

                            <div class="mb-4">
                                <label for="confirmPassword" class="form-label">Confirm Password</label>
                                <input id="confirmPassword" name="confirmPassword" type="password" class="form-control">
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary" type="submit">Update your password</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('./../parts/body-end') %>


