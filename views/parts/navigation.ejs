<div class="backdrop"></div>
<header class="main-header">
    <button id="side-menu-toggle">Menu</button>
    <nav class="main-header__nav">
        <ul class="main-header__item-list">
            <li class="main-header__item">
                <a class="<%= url === '/' ? 'active' : '' %>" href="/">Shop</a>
            </li>
            <li class="main-header__item">
                <a class="<%= url === '/products ' ? 'active' : '' %>" href="/products">Products</a>
            </li>
            <% if(isLoggedIn) { %>
                <li class="main-header__item">
                    <a class="<%= url === '/cart ' ? 'active' : '' %>" href="/cart">Cart</a>
                </li>
                <li class="main-header__item">
                    <a class="<%= url === '/orders ' ? 'active' : '' %>" href="/orders">Orders</a>
                </li>
                <li class="main-header__item">
                    <a class="<%= url === '/admin/add-product' ? 'active' : '' %>"
                       href="/admin/add-product">Add product</a>
                </li>
                <li class="main-header__item">
                    <a class="<%= url === '/admin/products' ? 'active' : '' %>"
                       href="/admin/products">Admin products</a>
                </li>
            <% } %>
        </ul>

        <ul class="main-header__item-list">
            <% if(!isLoggedIn) { %>
                <li class="main-header__item">
                    <a class="<%= url === '/login' ? 'active' : '' %>" href="/login">Login</a>
                </li>
                <li class="main-header__item">
                    <a class="<%= url === '/signup' ? 'active' : '' %>" href="/signup">Sign Up</a>
                </li>
            <% } else { %>
                <li class="main-header__item">
                    <a href="/logout">Logout</a>
                </li>
            <% } %>
        </ul>
    </nav>
</header>

<nav class="mobile-nav">
    <ul class="mobile-nav__item-list">
        <li class="mobile-nav__item">
            <a class="<%= url === '/' ? 'active' : '' %>" href="/">Shop</a>
        </li>
        <li class="mobile-nav__item">
            <a class="<%= url === '/products' ? 'active' : '' %>" href="/products">Products</a>
        </li>
        <li class="mobile-nav__item">
            <a class="<%= url === '/cart' ? 'active' : '' %>" href="/cart">Cart</a>
        </li>
        <li class="mobile-nav__item">
            <a class="<%= url === '/orders' ? 'active' : '' %>" href="/orders">Orders</a>
        </li>
        <li class="mobile-nav__item">
            <a class="<%= url === '/admin/add-product' ? 'active' : '' %>" href="/admin/add-product">Add Product
            </a>
        </li>
        <li class="mobile-nav__item">
            <a class="<%= url === '/admin/products' ? 'active' : '' %>" href="/admin/products">Admin Products
            </a>
        </li>
    </ul>
</nav>